{
    "name": "Churn Gradient Theme",
    "dataColors": [
        "#FF512F",
        "#F09819",
        "#1E293B",
        "#38BDF8",
        "#94A3B8",
        "#0F172A",
        "#F43F5E",
        "#10B981"
    ],
    "background": "#0F172A",
    "foreground": "#1E293B",
    "tableAccent": "#FF512F",
    "visualStyles": {
        "*": {
            "*": {
                "background": [
                    {
                        "show": true,
                        "color": { "solid": { "color": "#1E293B" } },
                        "transparency": 0
                    }
                ],
                "border": [
                    {
                        "show": true,
                        "color": { "solid": { "color": "#334155" } },
                        "radius": 8
                    }
                ],
                "title": [
                    {
                        "show": true,
                        "fontColor": { "solid": { "color": "#F8FAFC" } },
                        "fontSize": 12,
                        "fontFamily": "Segoe UI Semibold"
                    }
                ],
                "labels": [
                    {
                        "fontColor": { "solid": { "color": "#94A3B8" } }
                    }
                ]
            }
        },
        "page": {
            "*": {
                "background": [
                    {
                        "color": { "solid": { "color": "#0F172A" } },
                        "transparency": 0
                    }
                ]
            }
        }
    }
}
